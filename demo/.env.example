# 复制本文件为 .env 后填入真实 key:  cp .env.example .env

# 选哪个 provider: zhipu / siliconflow / dashscope / deepseek / ollama
PROVIDER=zhipu

# 可选：覆盖默认模型名（留空则用代码里 PROVIDERS 表中的默认值）
# MODEL=glm-4.7-flash

# --- 默认: 智谱 BigModel (GLM-4.7-Flash 免费) ---
# https://open.bigmodel.cn/  控制台 -> API Keys
ZHIPU_API_KEY=your-zhipu-key-here

# --- 可选: SiliconFlow (硅基流动)，注册送 14 元 ---
# SILICONFLOW_API_KEY=sk-xxx

# --- 可选: 阿里 DashScope (Qwen) ---
# DASHSCOPE_API_KEY=sk-xxx

# --- 可选: DeepSeek (极便宜, 非完全免费) ---
# DEEPSEEK_API_KEY=sk-xxx

# --- 可选: 本地 Ollama (完全免费, 需先 ollama pull qwen2.5:7b) ---
# OLLAMA_API_KEY=ollama
